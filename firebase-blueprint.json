{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the FightNet platform (fighter, fan, or sponsor).",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["fighter", "fan", "sponsor"] },
        "profileImageUrl": { "type": "string" },
        "bio": { "type": "string" },
        "record": { "type": "string" },
        "gym": { "type": "string" },
        "isPro": { "type": "boolean" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["displayName", "email", "role", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A media post, highlight, or update from a user.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["video", "image"] },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "reactions": { "type": "object", "description": "Map of userId to emoji" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["authorId", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["authorId", "text", "createdAt"]
    },
    "SponsorshipApplication": {
      "title": "Sponsorship Application",
      "description": "Application from a fighter to an advocating agent or brand.",
      "type": "object",
      "properties": {
        "fighterId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "pitch": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["fighterId", "status", "pitch", "createdAt"]
    },
    "VideoClip": {
      "title": "Video Clip",
      "description": "A short training video clip uploaded by a fighter.",
      "type": "object",
      "properties": {
        "fighterId": { "type": "string" },
        "title": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["fighterId", "videoUrl", "createdAt"]
    }
  },
  "firestore": {
    "/videoClips/{clipId}": {
      "schema": { "$ref": "#/entities/VideoClip" },
      "description": "Training video clips"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Feed posts"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Post comments"
    },
    "/sponsorships/{applicationId}": {
      "schema": { "$ref": "#/entities/SponsorshipApplication" },
      "description": "Sponsorship applications"
    }
  }
}
