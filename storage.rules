rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isImageOrVideo() {
      return request.resource.contentType.matches('(?i)^(image|video)/.*') ||
             request.resource.name.matches('(?i).*\\.(jpg|jpeg|png|gif|webp|mp4|mov|avi|wmv|webm|mkv|heic|heif)$');
    }

    match /posts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 200 * 1024 * 1024;
    }
    match /profiles/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
    match /videos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 200 * 1024 * 1024;
    }
    match /thumbnails/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 10 * 1024 * 1024;
    }
    match /contracts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
