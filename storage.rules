rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isImageOrVideo() {
      return request.resource.contentType.matches('(?i)^(image|video)/.*') ||
             request.resource.name.matches('(?i).*\\.(jpg|jpeg|png|gif|webp|mp4|mov|avi|wmv|webm|mkv|heic|heif)$');
    }

    match /posts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 200 * 1024 * 1024 // 200MB
                   && isImageOrVideo();
    }
    match /profiles/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 // 10MB
                   && (request.resource.contentType.matches('(?i)image/.*') || request.resource.name.matches('(?i).*\\.(jpg|jpeg|png|gif|webp|heic|heif)$'));
    }
    match /videos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 200 * 1024 * 1024 // 200MB
                   && (request.resource.contentType.matches('(?i)video/.*') || request.resource.name.matches('(?i).*\\.(mp4|mov|avi|wmv|webm|mkv)$'));
    }
    match /thumbnails/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 // 10MB
                   && (request.resource.contentType.matches('(?i)image/.*') || request.resource.name.matches('(?i).*\\.(jpg|jpeg|png|gif|webp|heic|heif)$'));
    }
    match /contracts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 20 * 1024 * 1024 // 20MB
                   && (request.resource.contentType.matches('(?i)image/.*|(?i)application/pdf') || request.resource.name.matches('(?i).*\\.(jpg|jpeg|png|pdf)$'));
    }
  }
}
